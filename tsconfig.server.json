{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"outDir": "server-dist",
		"noEmit": false,
		"allowImportingTsExtensions": false,
		"allowJs": false,
		"checkJs": false,
		"lib": ["ES2020"],
		"types": ["node"],
		"rootDir": "server-src"
	},
	"include": ["server-src/**/*.ts"],
	"exclude": ["node_modules"]
}


